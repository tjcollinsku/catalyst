# .gitignore — files Git should never track

# Environment variables — CRITICAL, never commit these
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
.venv/
venv/
*.egg-info/
dist/
build/

# Django
*.sqlite3
db.sqlite3
staticfiles/
media/

# Docker
*.log
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*~

# IDE
.vscode/
.idea/
*.code-workspace

# Binary documents — keep docs in markdown
*.docx
*.doc
*.xlsx
*.xls
*.pptx
~$*

# Investigation evidence and archives
Osgood Project Files/
*.zip
*.bak
evidence/
To The AG/

# Frontend (Node/Vite)
frontend/node_modules/
frontend/dist/
node_modules/

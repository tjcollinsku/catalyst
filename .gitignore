__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
.venv/
venv/
*.egg-info/

# Django
*.sqlite3
staticfiles/
media/

# Docker
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Investigation evidence and archives
Example Project Files/
*.zip
*.bak
evidence/
To The AG/
